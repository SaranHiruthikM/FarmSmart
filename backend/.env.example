# Server
PORT=4000
NODE_ENV=development

# Frontend origin for CORS (Vite default)
FRONTEND_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=change_me_super_long_random
JWT_EXPIRES_IN=7d
COOKIE_NAME=token

# Database (PostgreSQL example)
# If you prefer MySQL, update provider in prisma/schema.prisma and use a MySQL URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/farmsmart?schema=public"

# OTP
OTP_TTL_MINUTES=10

# Email (for dev you can leave these blank; OTP will be logged to console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FarmSmart <no-reply@farmsmart.local>"
