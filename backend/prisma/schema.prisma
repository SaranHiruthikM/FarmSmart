// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// User Roles based on platform participants
enum UserRole {
  FARMER
  BUYER
  COOPERATIVE
  ADMIN
  LOGISTICS
}

// Verification types
enum VerificationType {
  PHONE
  EMAIL
}

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  phoneNumber       String   @unique
  email             String?  @unique
  passwordHash      String
  
  role              UserRole @default(FARMER)
  
  fullName          String?
  
  // Location
  state             String
  district          String
  address           String?

  // Localization for Indian context
  preferredLanguage String   @default("en")
  
  isVerified        Boolean  @default(false)
  kycDocumentUrl    String?
  kycStatus         String   @default("NOT_SUBMITTED") // PENDING, APPROVED, REJECTED, NOT_SUBMITTED
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// For handling OTPs during Registration and Login (SMS/Email)
model VerificationCode {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  contact   String           // The phone number or email address
  code      String
  type      VerificationType
  expiresAt DateTime
  createdAt DateTime         @default(now())

  @@index([contact])
}

model Scheme {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  description         String
  benefits            String[]
  applyLink           String?
  eligibilityCriteria String?
  applicableStates    String[]
}

model Advisory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   @default("tip")
  title     String
  content   String
  crop      String?
  state     String?
  scheduledDate DateTime?
  isScheduled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Dispute {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId      String   @unique @db.ObjectId
  raisedBy     String   @db.ObjectId
  raisedByRole String
  reason       String
  description  String
  status       String   @default("OPEN")
  adminRemark  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model QualityRule {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  grade       String @unique
  multiplier  Float
  description String
  minSize     Float    @default(0)
  maxMoisture Float    @default(100)
}

